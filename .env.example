# ─────────────────────────────────────────────────────────────────────────────
# NexusBrief — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=NexusBrief
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string-before-deploying

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (zero install, perfect for local dev — this is the default)
DATABASE_URL=sqlite+aiosqlite:///./nexusbrief.db

# PostgreSQL (uncomment for production)
# DATABASE_URL=postgresql+asyncpg://nexusbrief:yourpassword@localhost:5432/nexusbrief

# ── Google Gemini AI ──────────────────────────────────────────────────────────
# Get your free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── News fetching ─────────────────────────────────────────────────────────────
# Number of articles to fetch per topic per run
ARTICLES_PER_FETCH=5

# Delete articles older than this many days (weekly cleanup)
MAX_ARTICLE_AGE_DAYS=30

# Set to true to attempt live RSS scraping instead of mock corpus
FETCH_LIVE=false

# ── CORS (add your frontend URL in production) ────────────────────────────────
# CORS_ORIGINS=["https://yourdomain.com","https://www.yourdomain.com"]
